---
// Imports
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
} from "@i18n/utils";
import { Image } from "astro:assets";
import navigationData from "@data/navigationData";
import logo from "@assets/logo.svg";

// Translations
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Current year
const currentYear = new Date().getFullYear();
---

<footer role="contentinfo" aria-labelledby="footer-title">
    <div class="container">
        <div>
            <p class="font-bold" style="font-size: 1.25rem;">Hyunseok's Blog</p>
        </div>

        <nav aria-label="Footer navigation">
            <h3 id="footer-title">{t("footer.index")}</h3>
            <ul role="list">
                {
                    navigationData.map(
                        (entry: any) =>
                            entry.href && (
                                <li>
                                    <a
                                        href={translatePath(entry.href)}
                                        tabindex="0"
                                        aria-label={t(entry.label)}
                                    >
                                        {t(entry.label)}
                                    </a>
                                </li>
                            )
                    )
                }
            </ul>
        </nav>
    </div>

    <div class="credit" role="complementary" aria-label="Site information">
        <a
            href="https://github.com/mathlee23"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t("footer.name")}`}
            tabindex="0"
            class="hover:opacity-50"
        >
            {t("footer.name")}
        </a>
        <span> // &copy; {t("footer.copy")} {currentYear}</span>
        <span> // {t("footer.made", { what: "Astro" })}</span>
    </div>
</footer>
